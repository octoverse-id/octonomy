DJANGO_SECRET_KEY=local-dev-secret
DJANGO_DEBUG=true
DATABASE_URL=postgres://octonomy:octonomy@localhost:5432/octonomy
ALLOWED_HOSTS=localhost,127.0.0.1
SERVICE_TOKEN_PEPPER=local-dev-service-token-pepper
OCTONOMY_API_VERSION=1.0.0
LOG_LEVEL=INFO
MAX_BULK_TAGS=200
# Namespace rollout control plane (see docs/operations.md). A Django system check
# refuses invalid combinations at boot. Enable order: SCHEMA -> READ -> AUTH ->
# V2_API -> WRITE. Rollback order: V2_API -> AUTH -> WRITE -> READ (SCHEMA stays).
OCTONOMY_NAMESPACE_SCHEMA_ENABLED=true
OCTONOMY_NAMESPACE_READ_ENABLED=true
OCTONOMY_NAMESPACE_AUTH_ENFORCED=true
OCTONOMY_NAMESPACE_V2_API_ENABLED=true
# Kill-switch for namespaced (merchant) writes. Off by default and flips last: v2
# reads are namespace-aware, but persisting namespaced rows is disabled until reads,
# auth, metrics, and the system check are all in place.
OCTONOMY_NAMESPACE_WRITE_ENABLED=false
OCTONOMY_OUTBOX_TRANSPORT=logging
OCTONOMY_WEBHOOK_URL=
OCTONOMY_WEBHOOK_SIGNING_SECRET=
OCTONOMY_WEBHOOK_TIMEOUT_SECONDS=10
OCTONOMY_OUTBOX_MAX_ATTEMPTS=5
OCTONOMY_OUTBOX_RETRY_BASE_SECONDS=30
OCTONOMY_OUTBOX_RETRY_MAX_SECONDS=3600
OCTONOMY_OUTBOX_CLAIM_TIMEOUT_SECONDS=60
