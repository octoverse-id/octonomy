DJANGO_SECRET_KEY=local-dev-secret
DJANGO_DEBUG=true
DATABASE_URL=postgres://octonomy:octonomy@localhost:5432/octonomy
ALLOWED_HOSTS=localhost,127.0.0.1
SERVICE_TOKEN_PEPPER=local-dev-service-token-pepper
OCTONOMY_API_VERSION=1.0.0
LOG_LEVEL=INFO
MAX_BULK_TAGS=200
OCTONOMY_OUTBOX_TRANSPORT=logging
OCTONOMY_WEBHOOK_URL=
OCTONOMY_WEBHOOK_SIGNING_SECRET=
OCTONOMY_WEBHOOK_TIMEOUT_SECONDS=10
OCTONOMY_OUTBOX_MAX_ATTEMPTS=5
OCTONOMY_OUTBOX_RETRY_BASE_SECONDS=30
OCTONOMY_OUTBOX_RETRY_MAX_SECONDS=3600
OCTONOMY_OUTBOX_CLAIM_TIMEOUT_SECONDS=60
